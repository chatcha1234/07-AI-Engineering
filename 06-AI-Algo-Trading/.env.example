# ── Binance API Configuration ──
# Copy this file to .env and fill in your keys
# NEVER commit .env to git!

# Testnet (Paper Trading) — Get keys from: https://testnet.binance.vision/
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_SECRET=your_testnet_secret_here

# Live (Real Money) — Get keys from: https://www.binance.com/en/my/settings/api-management
# ⚠️ Only use after thorough testnet testing!
# BINANCE_API_KEY=your_live_api_key_here
# BINANCE_SECRET=your_live_secret_here

# ── Trading Safety Limits ──
MAX_POSITION_USD=50
MAX_DAILY_TRADES=10
MAX_DAILY_LOSS_PCT=5
